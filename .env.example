# Google Search Console MCP Server Configuration
# Transport mode: 'stdio' (default) or 'http'
MCP_TRANSPORT=http

# HTTP port (only used when MCP_TRANSPORT=http)
HTTP_PORT=9100

# Optional: API key for HTTP mode authentication
# If set, all requests must include Authorization: Bearer <key>
# MCP_API_KEY=

# Google OAuth2 credentials (optional - can be provided via headers in HTTP mode)
# GSC_CLIENT_ID=your-client-id
# GSC_CLIENT_SECRET=your-client-secret
# GSC_REFRESH_TOKEN=your-refresh-token
